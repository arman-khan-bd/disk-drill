{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RescuR Data Recovery",
  "version": "1.0.0",
  "identifier": "com.rescur.datarecovery",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RescuR - Professional Data Recovery Engine",
        "width": 1280,
        "height": 830,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
